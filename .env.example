# ── Database — Supabase (development) / Aurora PostgreSQL (production) ──────────
DATABASE_URL=                        # Pooled connection string — used by Lambda and Next.js Route Handlers
DATABASE_URL_DIRECT=                 # Direct connection string — used by scripts and SQLModel create_all
DB_PROVIDER=                         # supabase | aurora

# ── AWS ──────────────────────────────────────────────────────────────────────────
AWS_REGION=                          # e.g. us-east-1
AWS_S3_BUCKET=                       # S3 bucket name for raw CSV uploads
AWS_LAMBDA_FUNCTION_NAME=            # Lambda function name for ingestion pipeline

# ── LLM APIs ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                   # Claude — reserved for future recommendations feature
OPENAI_API_KEY=                      # text-embedding-3-small — transaction and merchant embeddings

# ── LLM Normalization ─────────────────────────────────────────────────────────────
NORMALIZER_PROVIDER=openai           # openai or gemini
NORMALIZER_MODEL=gpt-4o-mini         # model name for the chosen provider
NORMALIZER_MAX_CONCURRENCY=5         # max concurrent LLM calls

# ── Geocoding ────────────────────────────────────────────────────────────────────
GEOCODING_API_KEY=                   # Merchant lat/lng enrichment

# ── Auth (NextAuth v5 / Auth.js) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=                    # Google OAuth client ID — console.cloud.google.com
GOOGLE_CLIENT_SECRET=                # Google OAuth client secret
NEXTAUTH_URL=                        # http://localhost:3000 for local dev
AUTH_SECRET=                         # Random secret — generate with: openssl rand -base64 32

# ── App ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=                 # e.g. http://localhost:3000
